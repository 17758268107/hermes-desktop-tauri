{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hermes Workspace",
  "version": "2.4.1",
  "identifier": "com.hermesworkspace.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://127.0.0.1:3000",
    "frontendDist": "../dist/client"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hermes Workspace",
        "width": 1480,
        "height": 940,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "visible": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "outsourc-e",
    "copyright": "Copyright \u00a9 2026 Hermes Workspace",
    "category": "DeveloperTool",
    "shortDescription": "Desktop workspace for Hermes Agent \u2014 chat, orchestration, multi-agent pipelines.",
    "longDescription": "Hermes Workspace is the native desktop shell for Hermes Agent. It walks you through first-run install of Hermes, manages the local Gateway + Dashboard lifecycle, and gives you a single window for chat, sessions, memory, skills, MCP, jobs, terminal, and Swarm dispatch. Tauri 2 + Bun + Vite + TanStack Start underneath; official Hermes install script under the hood.",
    "homepage": "https://github.com/outsourc-e/hermes-workspace",
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["English", "SimpChinese"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "127.0.0.1,localhost"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/17758268107/hermes-desktop-tauri/releases/latest/download/{{target}}-{{arch}}.json",
        "https://github.com/17758268107/hermes-desktop-tauri/releases/download/{{version}}/{{target}}-{{arch}}.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMwOEJBMkIyNEEzOUIyQ0EKUldUS3NqbEtzcUtMd0EvWWtaem9HZEJ2UVBiUjU0RUkrbmZuSEtHQVJjb0VuZnJuc2xVdGpHOGgK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
